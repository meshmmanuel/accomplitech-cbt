generator client {
  provider = "prisma-client-js"
}

// Switch provider to "postgresql" when using PostgreSQL DATABASE_URL
datasource db {
  provider = "sqlite"
}

enum UserRole {
  SUPER_ADMIN
  EXAM_OFFICER
  LECTURER
  INVIGILATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ExamType {
  OBJECTIVE
  THEORY
  BOTH
}

enum QuestionType {
  OBJECTIVE
  THEORY
}

enum SessionStatus {
  DRAFT
  UPCOMING
  OPEN
  CLOSED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum ClientActivity {
  IDLE
  INSTRUCTIONS
  IN_EXAM
  SUBMITTED
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  logoPath  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  subjects  Subject[]
  sessions  ExamSession[]
  clients   ExamClient[]
}

model User {
  id           String     @id @default(cuid())
  institutionId String
  email        String     @unique
  passwordHash String
  name         String
  role         UserRole   @default(EXAM_OFFICER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  institution     Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  auditLogs       AuditLog[]
  gradedAttempts  ExamAttempt[] @relation("GradedAttempts")
  subjectAssignments UserSubject[]
}

model Subject {
  id            String   @id @default(cuid())
  institutionId String
  code          String
  name          String
  department    String?
  description   String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  exams         Exam[]
  assignedUsers UserSubject[]

  @@unique([institutionId, code])
}

model Exam {
  id                        String   @id @default(cuid())
  subjectId                 String
  name                      String
  type                      ExamType
  durationMinutes           Int
  passMark                  Int
  totalMarks                Int      @default(100)
  randomizeQuestions        Boolean  @default(false)
  randomizeOptions          Boolean  @default(false)
  showResultsAfterSubmission Boolean  @default(true)
  negativeMarking           Boolean  @default(false)
  instructions              String?
  status                    String   @default("draft")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  subject                   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions                 Question[]
  sessionExams              ExamSessionExam[]
  attempts                  ExamAttempt[]
}

model Question {
  id            String       @id @default(cuid())
  examId        String
  questionType  String       @default("multiple_choice")
  type          QuestionType
  content       Json
  answer        Json?
  assets        Json?
  text          String
  imagePath     String?
  marks         Int          @default(1)
  topic         String?
  difficulty    String?
  options       Json?
  correctAnswer String?
  explanation   String?
  tags          String?
  status        String       @default("active")
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers       ExamAnswer[]
}

model ExamSession {
  id            String        @id @default(cuid())
  institutionId String
  name          String
  date          DateTime
  startTime     String?
  endTime       String?
  durationMinutes Int
  instructions  String?
  examCode      String        @unique
  status        SessionStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  sessionExams  ExamSessionExam[]
  attempts      ExamAttempt[]
  participations SessionParticipation[]
}

model SessionParticipation {
  id              String      @id @default(cuid())
  sessionId       String
  admissionNumber String
  startedAt       DateTime    @default(now())
  endedAt         DateTime?
  session         ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, admissionNumber])
}

model ExamSessionExam {
  id        String      @id @default(cuid())
  sessionId String
  examId    String
  isReleased Boolean    @default(false)
  releasedAt DateTime?
  session   ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exam      Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([sessionId, examId])
}

model ExamAttempt {
  id              String        @id @default(cuid())
  sessionId       String
  examId          String
  admissionNumber String
  displayName     String?
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  timeSpentSeconds Int?
  score           Float?
  theoryScore     Float?
  gradedAt        DateTime?
  gradedById      String?
  status          AttemptStatus @default(IN_PROGRESS)
  session         ExamSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exam            Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  gradedBy        User?         @relation("GradedAttempts", fields: [gradedById], references: [id], onDelete: SetNull)
  answers         ExamAnswer[]

  @@unique([sessionId, examId, admissionNumber])
  @@index([admissionNumber])
}

model ExamAnswer {
  id               String      @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOption   String?
  marksAwarded     Int?
  flaggedForReview Boolean     @default(false)
  answeredAt       DateTime?
  attempt          ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExamClient {
  id              String         @id
  institutionId   String?
  seatLabel       String?
  ipAddress       String?
  userAgent       String?
  activity        ClientActivity @default(IDLE)
  sessionId       String?
  admissionNumber String?
  activeAttemptId String?
  lastSeenAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  institution     Institution?   @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  connectionEvents ClientConnectionEvent[]

  @@index([lastSeenAt])
  @@index([institutionId])
}

model ClientConnectionEvent {
  id              String     @id @default(cuid())
  clientId        String
  eventType       String
  ipAddress       String?
  sessionId       String?
  admissionNumber String?
  detail          String?
  createdAt       DateTime   @default(now())
  client          ExamClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model UserSubject {
  id        String   @id @default(cuid())
  userId    String
  subjectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId])
  @@index([subjectId])
}
